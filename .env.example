# Telegram
TELEGRAM_BOT_TOKEN=

# Database (SQLite by default; switch to postgresql+asyncpg://... when scaling)
DATABASE_URL=sqlite+aiosqlite:///./shopping_bot.db

# Polling interval for source scans (seconds). Default 12h — Varus updates
# promos weekly, so more frequent polling wastes calls without catching more.
SCAN_INTERVAL_SECONDS=43200

# Varus
VARUS_DEFAULT_SHOP_ID=57
VARUS_REQUEST_TIMEOUT_SECONDS=15

# Logging
LOG_LEVEL=INFO
